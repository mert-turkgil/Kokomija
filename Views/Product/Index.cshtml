@model IEnumerable<Kokomija.Entity.Product>
@inject Kokomija.Services.ILocalizationService L
@inject Kokomija.Data.Abstract.IUnitOfWork UnitOfWork
@using System.Globalization

@{
    // Get current culture for translations
    var currentCulture = CultureInfo.CurrentCulture.TwoLetterISOLanguageName;
    var currentCultureCode = currentCulture == "pl" ? "pl-PL" : currentCulture == "en" ? "en-US" : "en-US";
    var currentCultureTwoLetter = CultureInfo.CurrentCulture.TwoLetterISOLanguageName;
    var currentCultureCodeForCategory = currentCultureTwoLetter == "pl" ? "pl-PL" : currentCultureTwoLetter == "en" ? "en-US" : "en-US";

    // Pre-load active coupons for coupon eligibility data attributes
    var activeCoupons = (await UnitOfWork.Coupons.GetActiveCouponsAsync()).ToList();
    var globalCoupons = activeCoupons.Where(c => c.CategoryId == null && c.ProductId == null && c.UserId == null).ToList();
    var categoryCouponMap = activeCoupons.Where(c => c.CategoryId.HasValue).GroupBy(c => c.CategoryId!.Value).ToDictionary(g => g.Key, g => g.ToList());
    var productCouponMap = activeCoupons.Where(c => c.ProductId.HasValue).GroupBy(c => c.ProductId!.Value).ToDictionary(g => g.Key, g => g.ToList());

    // Helper to get best coupon discount for a product
    decimal GetBestCouponDiscount(Kokomija.Entity.Product p) {
        var applicableCoupons = new List<Kokomija.Entity.Coupon>();
        applicableCoupons.AddRange(globalCoupons);
        if (p.CategoryId.HasValue && categoryCouponMap.TryGetValue(p.CategoryId.Value, out var catCoupons))
            applicableCoupons.AddRange(catCoupons);
        if (productCouponMap.TryGetValue(p.Id, out var prodCoupons))
            applicableCoupons.AddRange(prodCoupons);
        if (!applicableCoupons.Any()) return 0;
        return applicableCoupons.Max(c => c.DiscountType == "percentage" ? c.DiscountValue : (p.Price > 0 ? (c.DiscountValue / p.Price * 100) : 0));
    }
    
    // Helper function to get translated category name
    string GetCategoryName(Kokomija.Entity.Category? cat) {
        if (cat == null) return "";
        var translation = cat.Translations?.FirstOrDefault(t => t.CultureCode == currentCultureCodeForCategory)
                       ?? cat.Translations?.FirstOrDefault(t => t.CultureCode == "pl-PL");
        return translation?.Name ?? cat.Name;
    }
    
    // Set page title with translation
    var category = ViewBag.Category as Kokomija.Entity.Category;
    ViewData["Title"] = category != null 
        ? GetCategoryName(category)
        : (ViewBag.SearchQuery != null ? $"{L["Products_SearchResults"]}: {ViewBag.SearchQuery}" : L["Products_AllProducts"]);
}

<div class="products-page">
    <div class="container py-4">
        <!-- Breadcrumb Navigation & Item Count -->
        <div class="products-header mb-4">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb mb-0">
                            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">@L["Nav_Home"]</a></li>
                            @if (ViewBag.Category != null)
                            {
                                if (category?.ParentCategory != null)
                                {
                                    <li class="breadcrumb-item">
                                        <a asp-controller="Product" asp-action="Category" asp-route-slug="@category.ParentCategory.Slug">
                                            @GetCategoryName(category.ParentCategory)
                                        </a>
                                    </li>
                                }
                                <li class="breadcrumb-item active" aria-current="page">@GetCategoryName(category)</li>
                            }
                            else if (ViewBag.SearchQuery != null)
                            {
                                <li class="breadcrumb-item active" aria-current="page">@L["Products_SearchResults"]</li>
                            }
                            else
                            {
                                <li class="breadcrumb-item active" aria-current="page">@L["Products_AllProducts"]</li>
                            }
                        </ol>
                    </nav>
                </div>
                <div class="col-md-6 text-md-end">
                    <p class="products-count mb-0">
                        <strong>@Model.Count()</strong> @L["Products_ItemsFound_Plural"]
                    </p>
                </div>
            </div>
        </div>

        <!-- Filter Toggle Button -->
        <div class="row mb-3">
            <div class="col-12">
                <button class="btn btn-outline-primary" id="filterToggle">
                    <i class="bi bi-funnel me-2"></i>@L["Products_Filters"]
                </button>
            </div>
        </div>

        <div class="row">
            <!-- Filter Sidebar -->
            <div class="col-lg-3 filter-sidebar" id="filterSidebar">
                <div class="filter-card">
                    <div class="filter-header">
                        <h5>@L["Products_FilterBy"]</h5>
                        <button class="btn btn-link btn-sm text-danger" id="clearFilters">@L["Products_ClearAll"]</button>
                    </div>

                    <!-- Search by Product Name -->
                    <div class="filter-section">
                        <div class="filter-section-header mb-3">
                            <h6 class="filter-title mb-0">
                                <i class="bi bi-search me-2"></i>@L["Products_SearchByName"]
                            </h6>
                        </div>
                        <div class="search-filter">
                            <input type="text" class="form-control form-control-sm" id="productNameSearch" placeholder="@L["Products_EnterProductName"]">
                        </div>
                    </div>

                    <!-- Categories Filter -->
                    <div class="filter-section">
                        <div class="filter-section-header mb-3">
                            <h6 class="filter-title mb-0">
                                <i class="bi bi-tag me-2"></i>@L["Products_Categories"]
                            </h6>
                        </div>
                        <div id="categoryFilters" class="filter-options">
                            <!-- Will be populated dynamically -->
                        </div>
                    </div>

                    <!-- Price Range Filter -->
                    <div class="filter-section">
                        <div class="filter-section-header mb-3">
                            <h6 class="filter-title mb-0">
                                <i class="bi bi-currency-dollar me-2"></i>@L["Products_PriceRange"]
                            </h6>
                        </div>
                        <div class="price-filter">
                            <div class="row g-2">
                                <div class="col-6">
                                    <input type="number" class="form-control form-control-sm" id="minPrice" placeholder="@L["Products_MinPrice"]">
                                </div>
                                <div class="col-6">
                                    <input type="number" class="form-control form-control-sm" id="maxPrice" placeholder="@L["Products_MaxPrice"]">
                                </div>
                            </div>
                            <button class="btn btn-primary btn-sm w-100 mt-2" id="applyPriceFilter">@L["Products_Apply"]</button>
                        </div>
                    </div>

                    <!-- Colors Filter -->
                    <div class="filter-section">
                        <div class="filter-section-header mb-3">
                            <h6 class="filter-title mb-0">
                                <i class="bi bi-palette me-2"></i>@L["Products_Colors"]
                            </h6>
                        </div>
                        <div id="colorFilters" class="filter-options color-options">
                            <!-- Will be populated dynamically -->
                        </div>
                    </div>

                    <!-- Sizes Filter -->
                    <div class="filter-section">
                        <div class="filter-section-header mb-3">
                            <h6 class="filter-title mb-0">
                                <i class="bi bi-rulers me-2"></i>@L["Products_Sizes"]
                            </h6>
                        </div>
                        <div id="sizeFilters" class="filter-options size-options">
                            <!-- Will be populated dynamically -->
                        </div>
                    </div>

                    <!-- Product Type Filter -->
                    <div class="filter-section">
                        <div class="filter-section-header mb-3">
                            <h6 class="filter-title mb-0">
                                <i class="bi bi-box-seam me-2"></i>@L["Products_ProductType"]
                            </h6>
                        </div>
                        <div class="filter-options">
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="radio" id="allProducts" name="productType" value="all" checked>
                                <label class="form-check-label" for="allProducts">
                                    <i class="bi bi-grid me-1 text-secondary"></i>
                                    @L["Products_AllProducts"]
                                </label>
                            </div>
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="radio" id="singleProductsOnly" name="productType" value="single">
                                <label class="form-check-label" for="singleProductsOnly">
                                    <i class="bi bi-1-square me-1 text-success"></i>
                                    @L["Products_SingleOnly"]
                                </label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" id="bulkProductsOnly" name="productType" value="bulk">
                                <label class="form-check-label" for="bulkProductsOnly">
                                    <i class="bi bi-box2-heart me-1 text-info"></i>
                                    @L["Products_BulkOnly"]
                                </label>
                            </div>
                            <small class="text-muted d-block mt-2">
                                <i class="bi bi-info-circle me-1"></i>@L["Products_ProductTypeHint"]
                            </small>
                        </div>
                    </div>

                    <!-- Discount/Sale Filter -->
                    <div class="filter-section">
                        <div class="filter-section-header mb-3">
                            <h6 class="filter-title mb-0">
                                <i class="bi bi-percent me-2"></i>@L["Products_Discounts"]
                            </h6>
                        </div>
                        <div class="filter-options">
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" id="showDiscountsOnly" name="discount">
                                <label class="form-check-label" for="showDiscountsOnly">
                                    <i class="bi bi-gift me-1 text-danger"></i>
                                    @(L["Products_ShowOnSale"] ?? "On Sale")
                                </label>
                            </div>
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" id="showCouponEligible" name="couponEligible">
                                <label class="form-check-label" for="showCouponEligible">
                                    <i class="bi bi-ticket-perforated me-1 text-primary"></i>
                                    @(L["Products_HasCoupon"] ?? "Has Coupon")
                                </label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="showBestDeals" name="bestDeals">
                                <label class="form-check-label" for="showBestDeals">
                                    <i class="bi bi-lightning me-1 text-warning"></i>
                                    @(L["Products_BestDeals"] ?? "Best Deals")
                                </label>
                            </div>
                        </div>
                    </div>

                    <!-- Sort Options -->
                    <div class="filter-section">
                        <div class="filter-section-header mb-3">
                            <h6 class="filter-title mb-0">
                                <i class="bi bi-sort-down me-2"></i>@L["Products_SortBy"]
                            </h6>
                        </div>
                        <select class="form-select form-select-sm" id="sortBy">
                            <option value="newest">@L["Products_Sort_Newest"]</option>
                            <option value="price-asc">@L["Products_Sort_PriceAsc"]</option>
                            <option value="price-desc">@L["Products_Sort_PriceDesc"]</option>
                            <option value="name-asc">@L["Products_Sort_NameAsc"]</option>
                            <option value="name-desc">@L["Products_Sort_NameDesc"]</option>
                            <option value="discount">@L["Products_Sort_Discount"]</option>
                        </select>
                    </div>
                </div>
            </div>

            <!-- Products Grid -->
            <div class="col-lg-9 products-container">
                @if (globalCoupons.Any() || categoryCouponMap.Any())
                {
                    <div class="product-coupon-banner" id="listingCouponBanner">
                        <div class="coupon-section-header">
                            <h6 class="product-coupon-banner-title">
                                <i class="bi bi-ticket-perforated"></i> @(L["Products_AvailableCoupons"] ?? "Available Coupons")
                                <span class="coupon-section-count ms-1">@(globalCoupons.Count + categoryCouponMap.Values.Sum(v => v.Count))</span>
                            </h6>
                            <button type="button" class="btn btn-sm btn-link text-body-secondary p-0" onclick="document.getElementById('listingCouponBanner').style.display='none'" title="@(L["Products_DismissBanner"] ?? "Dismiss")">
                                <i class="bi bi-x-lg"></i>
                            </button>
                        </div>
                        <div class="coupon-strip">
                            @foreach (var coupon in globalCoupons.Take(5))
                            {
                                @await Html.PartialAsync("_CouponCard", new Kokomija.Models.ViewModels.CouponCardViewModel
                                {
                                    Id = coupon.Id,
                                    Code = coupon.Code,
                                    Description = coupon.Description,
                                    DiscountType = coupon.DiscountType,
                                    DiscountValue = coupon.DiscountValue,
                                    CouponType = coupon.CouponType,
                                    MinimumOrderAmount = coupon.MinimumOrderAmount,
                                    MaximumDiscountAmount = coupon.MaximumDiscountAmount,
                                    ValidUntil = coupon.ValidUntil,
                                    IsNew = coupon.CreatedAt >= DateTime.UtcNow.AddDays(-7)
                                }, new ViewDataDictionary(ViewData) { { "CouponCardMode", "compact" } })
                            }
                            @{
                                var categoryId = ViewBag.Category != null ? ((Kokomija.Entity.Category)ViewBag.Category).Id : (int?)null;
                            }
                            @if (categoryId.HasValue && categoryCouponMap.TryGetValue(categoryId.Value, out var currentCatCoupons))
                            {
                                @foreach (var coupon in currentCatCoupons.Take(3))
                                {
                                    @await Html.PartialAsync("_CouponCard", new Kokomija.Models.ViewModels.CouponCardViewModel
                                    {
                                        Id = coupon.Id,
                                        Code = coupon.Code,
                                        Description = coupon.Description,
                                        DiscountType = coupon.DiscountType,
                                        DiscountValue = coupon.DiscountValue,
                                        CouponType = coupon.CouponType,
                                        MinimumOrderAmount = coupon.MinimumOrderAmount,
                                        MaximumDiscountAmount = coupon.MaximumDiscountAmount,
                                        ValidUntil = coupon.ValidUntil,
                                        IsNew = coupon.CreatedAt >= DateTime.UtcNow.AddDays(-7),
                                        CategoryName = coupon.Category?.Name
                                    }, new ViewDataDictionary(ViewData) { { "CouponCardMode", "compact" } })
                                }
                            }
                        </div>
                    </div>
                }
                @if (!Model.Any())
                {
                    <div class="no-products">
                        <i class="bi bi-inbox display-1"></i>
                        <h3>@L["Products_NoProductsFound"]</h3>
                        <p>@L["Products_NoProductsDesc"]</p>
                        <a asp-action="Index" class="btn btn-primary">@L["Products_ViewAllProducts"]</a>
                    </div>
                }
                else
                {
                    <div class="products-grid row g-4" id="productsGrid">
                        @foreach (var product in Model)
                        {
                            var isBulkProduct = product.PackSize > 1;
                            
                            // Get translated names for search
                            var translatedNames = new List<string> { product.Name };
                            if (product.Translations != null && product.Translations.Any())
                            {
                                translatedNames.AddRange(product.Translations.Select(t => t.Name));
                            }
                            var allNames = string.Join("|", translatedNames.Distinct());
                            
                            // Get available colors for this product (from variants)
                            var productColors = product.Variants?.Where(v => v.ColorId.HasValue)
                                .Select(v => v.ColorId!.Value)
                                .Distinct()
                                .ToList() ?? new List<int>();
                            var colorsJson = string.Join(",", productColors);
                            
                            // Get available sizes for this product (from variants)
                            var productSizes = product.Variants?.Where(v => v.SizeId.HasValue)
                                .Select(v => v.SizeId!.Value)
                                .Distinct()
                                .ToList() ?? new List<int>();
                            var sizesJson = string.Join(",", productSizes);
                            
                            // Get coupon eligibility for this product
                            var bestCouponDiscount = GetBestCouponDiscount(product);
                            var hasCoupon = bestCouponDiscount > 0;
                            
                            <div class="col-md-6 col-lg-4" 
                                 data-category="@product.CategoryId" 
                                 data-price="@product.Price"
                                 data-name="@System.Net.WebUtility.HtmlEncode(product.Name)"
                                 data-translated-names="@System.Net.WebUtility.HtmlEncode(allNames)"
                                 data-created="@product.CreatedAt.Ticks"
                                 data-pack-size="@product.PackSize"
                                 data-is-bulk="@(isBulkProduct ? "true" : "false")"
                                 data-colors="@colorsJson"
                                 data-sizes="@sizesJson"
                                 data-has-coupon="@(hasCoupon ? "true" : "false")"
                                 data-coupon-discount="@bestCouponDiscount.ToString("F0")">
                                @await Component.InvokeAsync("ProductCard", new { productId = product.Id })
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // State management
            const filterState = {
                categories: [],
                colors: [],
                sizes: [],
                minPrice: null,
                maxPrice: null,
                sortBy: 'newest',
                showDiscountsOnly: false,
                showCouponEligible: false,
                showBestDeals: false,
                productType: 'all', // 'all', 'single', 'bulk'
                productName: '' // Search by product name
            };

            // Load search parameter from URL if it exists
            const urlParams = new URLSearchParams(window.location.search);
            const searchQuery = urlParams.get('q');
            if (searchQuery) {
                $('#productNameSearch').val(searchQuery);
                filterState.productName = searchQuery.toLowerCase().trim();
            }

            // Load filter options
            loadCategories();
            loadColors();
            loadSizes();

            // Apply filters if URL parameter exists - wait for products to be rendered
            if (searchQuery) {
                // Wait for products grid to have items before filtering
                const checkAndFilter = () => {
                    if ($('#productsGrid > div').length > 0) {
                        applyFilters();
                    } else {
                        setTimeout(checkAndFilter, 100);
                    }
                };
                checkAndFilter();
            }

            // Filter toggle with overlay
            $('#filterToggle').click(function() {
                $('#filterSidebar').addClass('show');
                $('.products-page').addClass('filter-open');
            });

            // Close filter sidebar (mobile)
            $('.filter-sidebar').on('click', function(e) {
                if ($(e.target).closest('.filter-card').length === 0 || $(e.target).is('.filter-sidebar::before')) {
                    closeFilterSidebar();
                }
            });

            // Close on overlay click
            $('.products-page').on('click', function(e) {
                if ($(e.target).is('.products-page.filter-open')) {
                    closeFilterSidebar();
                }
            });

            function closeFilterSidebar() {
                $('#filterSidebar').removeClass('show');
                $('.products-page').removeClass('filter-open');
            }

            // Filter logic with debouncing
            let filterTimeout;
            function triggerFilter() {
                clearTimeout(filterTimeout);
                filterTimeout = setTimeout(applyFilters, 300);
            }

            function applyFilters() {
                // Update state
                filterState.categories = $('input[name="category"]:checked').map(function() {
                    return parseInt($(this).val());
                }).get();

                filterState.colors = $('input[name="color"]:checked').map(function() {
                    return parseInt($(this).val());
                }).get();

                filterState.sizes = $('.size-btn.active').map(function() {
                    return parseInt($(this).data('size'));
                }).get();

                filterState.minPrice = parseFloat($('#minPrice').val()) || 0;
                filterState.maxPrice = parseFloat($('#maxPrice').val()) || Infinity;
                filterState.sortBy = $('#sortBy').val();
                filterState.showDiscountsOnly = $('#showDiscountsOnly').prop('checked');
                filterState.showCouponEligible = $('#showCouponEligible').prop('checked');
                filterState.showBestDeals = $('#showBestDeals').prop('checked');
                filterState.productType = $('input[name="productType"]:checked').val() || 'all';
                filterState.productName = $('#productNameSearch').val().toLowerCase().trim();
                let $products = $('#productsGrid > div');
                let visibleCount = 0;

                // Filter products
                $products.each(function() {
                    const $product = $(this);
                    const productCategory = parseInt($product.data('category'));
                    const productPrice = parseFloat($product.data('price'));
                    
                    // Get product names - include all translations for multilingual search
                    let productName = $product.data('name');
                    let translatedNames = $product.data('translated-names');
                    
                    if (!productName) {
                        productName = '';
                    }
                    
                    // Combine base name and all translated names for search
                    let searchableNames = productName.toString().toLowerCase().trim();
                    if (translatedNames) {
                        searchableNames = translatedNames.toString().toLowerCase().trim();
                    }
                    
                    const packSize = parseInt($product.data('pack-size')) || 1;
                    const isBulk = $product.attr('data-is-bulk') === 'true';
                    const isSingle = !isBulk; // Single = PackSize == 1
                    const hasDiscount = $product.find('.price-with-discount, .discount-badge, .badge-sale').length > 0;
                    
                    // Get product colors and sizes
                    const productColorsStr = $product.data('colors') || '';
                    const productSizesStr = $product.data('sizes') || '';
                    const productColors = productColorsStr ? productColorsStr.toString().split(',').map(c => parseInt(c)) : [];
                    const productSizes = productSizesStr ? productSizesStr.toString().split(',').map(s => parseInt(s)) : [];
                    
                    let showProduct = true;

                    // Filter by product name - search in all translated names
                    if (filterState.productName) {
                        if (!searchableNames || !searchableNames.includes(filterState.productName)) {
                            showProduct = false;
                        }
                    }

                    // Filter by category
                    if (showProduct && filterState.categories.length > 0 && !filterState.categories.includes(productCategory)) {
                        showProduct = false;
                    }

                    // Filter by price
                    if (showProduct && (productPrice < filterState.minPrice || productPrice > filterState.maxPrice)) {
                        showProduct = false;
                    }
                    
                    // Filter by colors - product must have at least one of the selected colors
                    if (showProduct && filterState.colors.length > 0) {
                        const hasMatchingColor = filterState.colors.some(colorId => productColors.includes(colorId));
                        if (!hasMatchingColor) {
                            showProduct = false;
                        }
                    }
                    
                    // Filter by sizes - product must have at least one of the selected sizes
                    if (showProduct && filterState.sizes.length > 0) {
                        const hasMatchingSize = filterState.sizes.some(sizeId => productSizes.includes(sizeId));
                        if (!hasMatchingSize) {
                            showProduct = false;
                        }
                    }
                    
                    // Filter by discount — on sale items
                    if (showProduct && filterState.showDiscountsOnly && !hasDiscount) {
                        showProduct = false;
                    }
                    
                    // Filter by coupon eligible
                    if (showProduct && filterState.showCouponEligible) {
                        const hasCoupon = $product.attr('data-has-coupon') === 'true';
                        if (!hasCoupon) {
                            showProduct = false;
                        }
                    }
                    
                    // Filter by best deals (has discount OR has coupon)
                    if (showProduct && filterState.showBestDeals) {
                        const hasCoupon = $product.attr('data-has-coupon') === 'true';
                        if (!hasDiscount && !hasCoupon) {
                            showProduct = false;
                        }
                    }

                    // Filter by product type (all/single/bulk)
                    if (filterState.productType === 'single' && !isSingle) {
                        showProduct = false;
                    }
                    if (filterState.productType === 'bulk' && !isBulk) {
                        showProduct = false;
                    }

                    // Show/hide with animation
                    if (showProduct) {
                        $product.fadeIn(300);
                        visibleCount++;
                    } else {
                        $product.fadeOut(200);
                    }
                });

                // Sort products
                sortProducts(filterState.sortBy);

                // Update count with animation
                $('.products-count').fadeOut(200, function() {
                    $(this).html('<strong>' + visibleCount + '</strong> @L["Products_ItemsFound_Plural"]').fadeIn(200);
                });

                // Show/hide no products message
                if (visibleCount === 0) {
                    if ($('.no-products-filter').length === 0) {
                        $('#productsGrid').after(`
                            <div class="no-products no-products-filter" style="display:none;">
                                <i class="bi bi-inbox display-1"></i>
                                <h3>@L["Products_NoProductsFound"]</h3>
                                <p>@L["Products_TryAdjustingFilters"]</p>
                                <button class="btn btn-primary" id="resetFiltersBtn">@L["Products_ClearAll"]</button>
                            </div>
                        `).find('.no-products-filter').fadeIn(400);
                    }
                } else {
                    $('.no-products-filter').fadeOut(300, function() { $(this).remove(); });
                }

                // Close filter sidebar on mobile after applying
                if ($(window).width() < 992) {
                    setTimeout(closeFilterSidebar, 400);
                }

                // Smooth scroll to products
                if ($(window).scrollTop() > $('.products-header').offset().top) {
                    $('html, body').animate({
                        scrollTop: $('.products-header').offset().top - 20
                    }, 400);
                }
            }

            function sortProducts(sortBy) {
                const $container = $('#productsGrid');
                const $products = $container.children('div').get();

                $products.sort(function(a, b) {
                    const $a = $(a);
                    const $b = $(b);

                    switch(sortBy) {
                        case 'price-asc':
                            return $a.data('price') - $b.data('price');
                        case 'price-desc':
                            return $b.data('price') - $a.data('price');
                        case 'name-asc':
                            return $a.data('name').toString().localeCompare($b.data('name').toString());
                        case 'name-desc':
                            return $b.data('name').toString().localeCompare($a.data('name').toString());
                        case 'newest':
                        default:
                            return $b.data('created') - $a.data('created');
                    }
                });

                // Detach all products and reattach in sorted order
                $.each($products, function(idx, item) {
                    $container.append(item);
                });
            }

            // Event listeners (excluding category - handled by attachCategoryHandlers)
            $(document).on('change', 'input[name="color"], input[name="productType"], #sortBy, #showDiscountsOnly, #showCouponEligible, #showBestDeals', triggerFilter);
            $('#applyPriceFilter').click(applyFilters);
            $('#minPrice, #maxPrice').on('keyup', function(e) {
                if (e.keyCode === 13) { // Enter key
                    applyFilters();
                }
            });

            // Product name search with URL updates
            let searchTimeout;
            $('#productNameSearch').on('keyup', function() {
                clearTimeout(searchTimeout);
                const searchValue = $(this).val().trim();
                
                // Trigger filter immediately
                triggerFilter();
                
                // Update URL after a short delay (500ms)
                searchTimeout = setTimeout(function() {
                    if (searchValue) {
                        // Update URL to include search parameter
                        const newUrl = new URL(window.location);
                        newUrl.searchParams.set('q', searchValue);
                        window.history.pushState({}, '', newUrl);
                    } else {
                        // Remove search parameter if empty
                        const newUrl = new URL(window.location);
                        newUrl.searchParams.delete('q');
                        window.history.pushState({}, '', newUrl);
                    }
                }, 500);
            });

            // Size button toggle
            $(document).on('click', '.size-btn', function() {
                $(this).toggleClass('active');
                triggerFilter();
            });

            // Clear filters
            $('#clearFilters, #resetFiltersBtn').click(function() {
                $('input[type="checkbox"]').prop('checked', false).prop('indeterminate', false);
                $('input[name="productType"][value="all"]').prop('checked', true); // Reset to "All Products"
                $('.size-btn').removeClass('active');
                $('#minPrice, #maxPrice').val('');
                $('#productNameSearch').val('');
                $('#sortBy').val('newest');
                $('#showDiscountsOnly').prop('checked', false);
                $('#showCouponEligible').prop('checked', false);
                $('#showBestDeals').prop('checked', false);
                
                filterState.categories = [];
                filterState.colors = [];
                filterState.sizes = [];
                filterState.minPrice = null;
                filterState.maxPrice = null;
                filterState.sortBy = 'newest';
                filterState.showDiscountsOnly = false;
                filterState.showCouponEligible = false;
                filterState.showBestDeals = false;
                filterState.productType = 'all';
                filterState.productName = '';

                // Clear URL parameters
                const newUrl = new URL(window.location);
                newUrl.search = '';
                window.history.pushState({}, '', newUrl);

                // Show all products - stop any animations and ensure proper display
                $('#productsGrid > div').stop(true, true).css({
                    'display': '',
                    'opacity': '1'
                }).show();
                
                const totalProducts = $('#productsGrid > div').length;
                $('.products-count').fadeOut(200, function() {
                    $(this).html('<strong>' + totalProducts + '</strong> @L["Products_ItemsFound_Plural"]').fadeIn(200);
                });
                $('.no-products-filter').fadeOut(300, function() { $(this).remove(); });
                
                // Scroll to top
                $('html, body').animate({
                    scrollTop: $('.products-header').offset().top - 20
                }, 400);
            });

            // Load categories with error handling and grouping
            function loadCategories() {
                $.get('/Product/GetCategories')
                    .done(function(data) {
                        if (!data || data.length === 0) {
                            $('#categoryFilters').html('<p class="text-muted small">No categories available</p>');
                            return;
                        }

                        // Separate parent categories and subcategories
                        const parents = data.filter(cat => cat.isParent);
                        const children = data.filter(cat => !cat.isParent);

                        let html = '';
                        
                        // Loop through parent categories
                        parents.forEach(parent => {
                            const subcategories = children.filter(child => child.parentId === parent.id);
                            
                            html += `<div class="category-group mb-3">`;
                            
                            // Parent category with checkbox and optional image
                            const parentIcon = parent.iconImagePath || parent.iconCssClass;
                            let parentIconHtml = '';
                            if (parent.iconImagePath) {
                                parentIconHtml = `<img src="${parent.iconImagePath}" alt="${parent.name}" class="category-icon me-1" style="width: 20px; height: 20px; object-fit: contain;" onerror="this.style.display='none'">`;
                            } else if (parent.iconCssClass) {
                                parentIconHtml = `<i class="${parent.iconCssClass} me-1"></i>`;
                            }
                            
                            html += `
                                <div class="form-check mb-2">
                                    <input class="form-check-input parent-category" type="checkbox" name="category" value="${parent.id}" id="cat${parent.id}" data-parent-id="${parent.id}">
                                    <label class="form-check-label fw-bold d-flex align-items-center" for="cat${parent.id}">
                                        ${parentIconHtml}
                                        <span>${parent.name}</span>
                                    </label>
                                </div>
                            `;
                            
                            // Subcategories indented with icons/images
                            if (subcategories.length > 0) {
                                html += `<div class="ps-3 child-categories" data-parent="${parent.id}">`;
                                subcategories.forEach(cat => {
                                    let iconHtml = '';
                                    if (cat.iconImagePath) {
                                        iconHtml = `<img src="${cat.iconImagePath}" alt="${cat.name}" class="category-icon me-1" style="width: 18px; height: 18px; object-fit: contain;" onerror="this.style.display='none'">`;
                                    } else if (cat.iconCssClass) {
                                        iconHtml = `<i class="${cat.iconCssClass} me-1"></i>`;
                                    }
                                    
                                    html += `
                                        <div class="form-check">
                                            <input class="form-check-input child-category" type="checkbox" name="category" value="${cat.id}" id="cat${cat.id}" data-parent-id="${parent.id}">
                                            <label class="form-check-label d-flex align-items-center" for="cat${cat.id}">
                                                ${iconHtml}
                                                <span>${cat.name}</span>
                                            </label>
                                        </div>
                                    `;
                                });
                                html += `</div>`;
                            }
                            
                            html += `</div>`;
                        });
                        
                        $('#categoryFilters').html(html);
                        
                        // Attach event handlers after DOM is updated
                        attachCategoryHandlers();
                    })
                    .fail(function(xhr, status, error) {
                        console.error('Failed to load categories:', error);
                        $('#categoryFilters').html('<p class="text-danger small">Failed to load categories</p>');
                    });
            }

            // Parent/child category checkbox logic
            function attachCategoryHandlers() {
                // When parent category is checked/unchecked, toggle all children
                $(document).on('change', '.parent-category', function() {
                    const parentId = $(this).data('parent-id');
                    const isChecked = $(this).prop('checked');
                    
                    // Check/uncheck all child categories
                    $(`.child-category[data-parent-id="${parentId}"]`).prop('checked', isChecked);
                    
                    // Trigger filter
                    triggerFilter();
                });
                
                // When child category changes, update parent state
                $(document).on('change', '.child-category', function() {
                    const parentId = $(this).data('parent-id');
                    const $parent = $(`.parent-category[data-parent-id="${parentId}"]`);
                    const $siblings = $(`.child-category[data-parent-id="${parentId}"]`);
                    
                    // Check if all children are checked
                    const allChecked = $siblings.length === $siblings.filter(':checked').length;
                    const someChecked = $siblings.filter(':checked').length > 0;
                    
                    // Update parent checkbox state
                    $parent.prop('checked', allChecked);
                    $parent.prop('indeterminate', !allChecked && someChecked);
                    
                    // Trigger filter
                    triggerFilter();
                });
            }

            // Load colors with visual swatches
            function loadColors() {
                $.get('/Product/GetColors')
                    .done(function(data) {
                        if (!data || data.length === 0) {
                            $('#colorFilters').html('<p class="text-muted small">No colors available</p>');
                            return;
                        }

                        const html = data.map(color => `
                            <div class="color-option">
                                <input type="checkbox" name="color" value="${color.id}" id="color${color.id}" class="color-checkbox">
                                <label for="color${color.id}" class="color-label" title="${color.displayName}">
                                    <span class="color-swatch" style="background-color: ${color.hexCode}"></span>
                                    <span class="color-name">${color.displayName}</span>
                                </label>
                            </div>
                        `).join('');
                        $('#colorFilters').html(html);
                    })
                    .fail(function(xhr, status, error) {
                        console.error('Failed to load colors:', error);
                        $('#colorFilters').html('<p class="text-danger small">Failed to load colors</p>');
                    });
            }

            // Load sizes with toggle buttons
            function loadSizes() {
                $.get('/Product/GetSizes')
                    .done(function(data) {
                        if (!data || data.length === 0) {
                            $('#sizeFilters').html('<p class="text-muted small">No sizes available</p>');
                            return;
                        }

                        const html = data.map(size => `
                            <button type="button" class="size-btn" data-size="${size.id}">
                                ${size.displayName}
                            </button>
                        `).join('');
                        $('#sizeFilters').html(html);
                    })
                    .fail(function(xhr, status, error) {
                        console.error('Failed to load sizes:', error);
                        $('#sizeFilters').html('<p class="text-danger small">Failed to load sizes</p>');
                    });
            }

            // Keyboard shortcuts
            $(document).on('keydown', function(e) {
                // Escape key closes filter sidebar
                if (e.key === 'Escape' && $('#filterSidebar').hasClass('show')) {
                    closeFilterSidebar();
                }
            });

            // Lazy load product images
            if ('IntersectionObserver' in window) {
                const imageObserver = new IntersectionObserver((entries) => {
                    entries.forEach(entry => {
                        if (entry.isIntersecting) {
                            const img = entry.target;
                            img.src = img.dataset.src;
                            img.classList.remove('lazy');
                            imageObserver.unobserve(img);
                        }
                    });
                });

                document.querySelectorAll('img.lazy').forEach(img => imageObserver.observe(img));
            }

            // Handle image load errors - fallback to logo
            $(document).on('error', '.product-card img, #productsGrid img', function() {
                if (!$(this).hasClass('error-handled')) {
                    $(this).addClass('error-handled');
                    $(this).attr('src', '/img/logo.png');
                    $(this).attr('alt', 'Product image not available');
                }
            });

            // Re-observe images after filtering
            function reObserveImages() {
                if ('IntersectionObserver' in window) {
                    document.querySelectorAll('img.lazy:not(.observed)').forEach(img => {
                        img.classList.add('observed');
                        const observer = new IntersectionObserver((entries) => {
                            entries.forEach(entry => {
                                if (entry.isIntersecting) {
                                    const image = entry.target;
                                    if (image.dataset.src) {
                                        image.src = image.dataset.src;
                                    }
                                    image.classList.remove('lazy');
                                    observer.unobserve(image);
                                }
                            });
                        });
                        observer.observe(img);
                    });
                }
            }

            // Call reObserveImages when filtering completes
            const originalApplyFilters = applyFilters;
            applyFilters = function() {
                originalApplyFilters();
                setTimeout(reObserveImages, 100);
            };
        });
    </script>
}

