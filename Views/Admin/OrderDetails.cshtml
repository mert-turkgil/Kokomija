@model Kokomija.Models.ViewModels.Admin.OrderDetailsViewModel
@{
    ViewData["Title"] = $"Order #{Model.OrderNumber}";
    var statusColor = Model.OrderStatus.ToLower() switch {
        "pending" => "#ffc107",
        "processing" => "#0dcaf0",
        "shipped" => "#0d6efd",
        "delivered" => "#198754",
        "cancelled" => "#dc3545",
        _ => "#6c757d"
    };
    var payColor = Model.PaymentStatus.ToLower() switch {
        "paid" => "#198754",
        "pending" => "#ffc107",
        "failed" => "#dc3545",
        "refunded" => "#6c757d",
        _ => "#6c757d"
    };
    var steps = new[] { "pending", "processing", "shipped", "delivered" };
    var currentStep = Array.IndexOf(steps, Model.OrderStatus.ToLower());
    if (currentStep == -1) currentStep = 0;
    var isCancelled = Model.OrderStatus.ToLower() == "cancelled";
}

<div class="admin-dashboard">
<div class="container-fluid py-4">

    <!-- ===== HERO HEADER ===== -->
    <div class="ao-hero">
        <div class="ao-hero-bg" style="background: linear-gradient(135deg, @statusColor 0%, color-mix(in srgb, @statusColor, #1a1a2e 50%) 100%);"></div>
        <div class="ao-hero-content">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
                <div>
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <h1 class="ao-hero-title mb-0">Order #@Model.OrderNumber</h1>
                        @if (Model.IsDemoOrder)
                        {
                            <span class="badge bg-warning text-dark"><i class="bi bi-cone-striped"></i> DEMO</span>
                        }
                    </div>
                    <div class="ao-hero-meta">
                        <span><i class="bi bi-calendar3"></i> @Model.CreatedAt.ToString("MMM dd, yyyy 'at' HH:mm")</span>
                        <span class="ao-meta-divider">|</span>
                        <span><i class="bi bi-person"></i> @Model.CustomerName</span>
                        <span class="ao-meta-divider">|</span>
                        <span><i class="bi bi-currency-exchange"></i> @Model.TotalAmount.ToString("N2") @Model.Currency</span>
                    </div>
                    <div class="d-flex gap-2 mt-3 flex-wrap">
                        <span class="ao-pill ao-pill-order" style="--pill-color: @statusColor;">
                            <i class="bi bi-circle-fill" style="font-size: 0.5rem;"></i>@Model.OrderStatus.ToUpper()
                        </span>
                        <span class="ao-pill ao-pill-payment" style="--pill-color: @payColor;">
                            <i class="bi bi-credit-card"></i>@Model.PaymentStatus.ToUpper()
                        </span>
                    </div>
                </div>
                <div class="d-flex gap-2 flex-wrap">
                    @if (Model.OrderStatus != "cancelled" && Model.OrderStatus != "delivered")
                    {
                        <button type="button" class="btn btn-light btn-sm" data-bs-toggle="modal" data-bs-target="#updateStatusModal">
                            <i class="bi bi-arrow-repeat"></i> Change Status
                        </button>
                    }
                    <a asp-action="Orders" class="btn btn-outline-light btn-sm">
                        <i class="bi bi-arrow-left"></i> Back to Orders
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- ===== ORDER PROGRESS ===== -->
    @if (!isCancelled)
    {
        <div class="ao-progress-card">
            <div class="ao-progress-track">
                @{var progressPct = currentStep == 0 ? 0 : (currentStep * 100) / (steps.Length - 1);}
                <div class="ao-progress-line"><div class="ao-progress-fill" style="width: @(progressPct)%; background: @statusColor;"></div></div>
                @foreach (var (step, idx) in steps.Select((s, i) => (s, i)))
                {
                    var completed = idx < currentStep;
                    var active = idx == currentStep;
                    <div class="ao-pstep @(completed ? "done" : "") @(active ? "active" : "")" style="--step-color: @statusColor;">
                        <div class="ao-pstep-dot">
                            @if (completed) { <i class="bi bi-check-lg"></i> } else { <span>@(idx + 1)</span> }
                        </div>
                        <div class="ao-pstep-label">@(System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(step))</div>
                        @if (step == "pending") { <div class="ao-pstep-date">@Model.CreatedAt.ToString("dd MMM, HH:mm")</div> }
                        else if (step == "shipped" && Model.ShippedAt.HasValue) { <div class="ao-pstep-date">@Model.ShippedAt.Value.ToString("dd MMM, HH:mm")</div> }
                        else if (step == "delivered" && Model.DeliveredAt.HasValue) { <div class="ao-pstep-date">@Model.DeliveredAt.Value.ToString("dd MMM, HH:mm")</div> }
                    </div>
                }
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-danger border-0 d-flex align-items-center gap-3 rounded-3 shadow-sm my-3">
            <i class="bi bi-x-octagon-fill fs-2"></i>
            <div><strong>Order Cancelled</strong><div class="small opacity-75">This order has been cancelled and is no longer active.</div></div>
        </div>
    }

    <!-- ===== QUICK STATS ROW ===== -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="ao-stat-card">
                <div class="ao-stat-icon" style="background: rgba(13,110,253,0.12); color: #0d6efd;"><i class="bi bi-box-seam"></i></div>
                <div>
                    <div class="ao-stat-value">@Model.OrderItems.Count</div>
                    <div class="ao-stat-label">Items</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="ao-stat-card">
                <div class="ao-stat-icon" style="background: rgba(25,135,84,0.12); color: #198754;"><i class="bi bi-cash-stack"></i></div>
                <div>
                    <div class="ao-stat-value">@Model.TotalAmount.ToString("N2")</div>
                    <div class="ao-stat-label">Total (@Model.Currency)</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="ao-stat-card">
                <div class="ao-stat-icon" style="background: rgba(255,193,7,0.12); color: #ffc107;"><i class="bi bi-percent"></i></div>
                <div>
                    <div class="ao-stat-value">@Model.CommissionAmount.ToString("N2")</div>
                    <div class="ao-stat-label">Commission</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="ao-stat-card">
                <div class="ao-stat-icon" style="background: rgba(220,53,69,0.12); color: #dc3545;"><i class="bi bi-receipt"></i></div>
                <div>
                    <div class="ao-stat-value">@Model.TaxAmount.ToString("N2")</div>
                    <div class="ao-stat-label">Tax (VAT @(Model.TaxRate * 100)%)</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- ===== LEFT COLUMN ===== -->
        <div class="col-xl-8">
            <!-- Order Items -->
            <div class="ao-card mb-4">
                <div class="ao-card-header">
                    <h5><i class="bi bi-bag-check-fill"></i> Order Items <span class="ao-badge">@Model.OrderItems.Count</span></h5>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover mb-0 ao-items-table">
                        <thead>
                            <tr>
                                <th style="width: 50%;">Product</th>
                                <th class="text-center">Qty</th>
                                <th class="text-end">Unit Price</th>
                                <th class="text-end">Total</th>
                                <th class="text-center">Return</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.OrderItems)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="ao-item-img">
                                                @if (item.ProductImageUrl != null)
                                                {
                                                    <img src="@item.ProductImageUrl" alt="@item.ProductName">
                                                }
                                                else
                                                {
                                                    <div class="ao-item-img-placeholder"><i class="bi bi-image"></i></div>
                                                }
                                            </div>
                                            <div>
                                                <div class="fw-semibold">@item.ProductName</div>
                                                <div class="small text-muted">
                                                    @if (!string.IsNullOrEmpty(item.Color)) { <span class="me-2"><i class="bi bi-palette"></i> @item.Color</span> }
                                                    @if (!string.IsNullOrEmpty(item.Size)) { <span><i class="bi bi-rulers"></i> @item.Size</span> }
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-center align-middle"><span class="badge bg-body-secondary text-body rounded-pill px-3">@item.Quantity</span></td>
                                    <td class="text-end align-middle">@item.UnitPrice.ToString("N2") @Model.Currency</td>
                                    <td class="text-end align-middle fw-bold">@item.TotalPrice.ToString("N2") @Model.Currency</td>
                                    <td class="text-center align-middle">
                                        @if (item.HasActiveReturn)
                                        {
                                            <span class="badge bg-warning text-dark"><i class="bi bi-arrow-return-left"></i> @item.ReturnStatus</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <!-- Order Financial Summary -->
                <div class="ao-financial-summary">
                    <div class="row">
                        <div class="col-md-6"></div>
                        <div class="col-md-6">
                            <div class="ao-fin-row"><span>Subtotal</span><span>@Model.SubtotalAmount.ToString("N2") @Model.Currency</span></div>
                            @if (Model.DiscountAmount > 0)
                            {
                                <div class="ao-fin-row ao-fin-discount">
                                    <span><i class="bi bi-tag-fill"></i> Discount @(!string.IsNullOrEmpty(Model.CouponCode) ? $"({Model.CouponCode})" : "")</span>
                                    <span>-@Model.DiscountAmount.ToString("N2") @Model.Currency</span>
                                </div>
                            }
                            <div class="ao-fin-row"><span><i class="bi bi-truck"></i> Shipping</span><span>@Model.ShippingCost.ToString("N2") @Model.Currency</span></div>
                            @if (Model.TaxAmount > 0)
                            {
                                <div class="ao-fin-row"><span>Tax (VAT @(Model.TaxRate * 100)%)</span><span>@Model.TaxAmount.ToString("N2") @Model.Currency</span></div>
                            }
                            @if (Model.CommissionAmount > 0)
                            {
                                <div class="ao-fin-row"><span><i class="bi bi-bank"></i> Commission (@(Model.CommissionRate * 100)%)</span><span>@Model.CommissionAmount.ToString("N2") @Model.Currency</span></div>
                            }
                            <div class="ao-fin-total"><span>Total</span><span>@Model.TotalAmount.ToString("N2") @Model.Currency</span></div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Shipment Information -->
            @if (Model.Shipment != null)
            {
                <div class="ao-card mb-4">
                    <div class="ao-card-header">
                        <h5><i class="bi bi-truck"></i> Shipment Information</h5>
                        <span class="ao-status-tag ao-ship-@Model.Shipment.Status.ToString().ToLower()">@Model.Shipment.Status</span>
                    </div>
                    <div class="ao-card-body">
                        <div class="row g-3">
                            <div class="col-md-4">
                                <div class="ao-detail-block">
                                    <div class="ao-detail-label">Provider</div>
                                    <div class="ao-detail-value">@Model.Shipment.ProviderName</div>
                                    <div class="small text-muted">@Model.Shipment.RateName</div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="ao-detail-block">
                                    <div class="ao-detail-label">Tracking Number</div>
                                    <div class="ao-detail-value">
                                        <code class="ao-tracking-code">@Model.Shipment.TrackingNumber</code>
                                        @if (!string.IsNullOrEmpty(Model.Shipment.TrackingUrl))
                                        {
                                            <a href="@Model.Shipment.TrackingUrl" target="_blank" class="ms-1"><i class="bi bi-box-arrow-up-right"></i></a>
                                        }
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="ao-detail-block">
                                    <div class="ao-detail-label">Estimated Delivery</div>
                                    <div class="ao-detail-value">@(Model.Shipment.EstimatedDeliveryDate?.ToString("MMM dd, yyyy") ?? "N/A")</div>
                                    @if (Model.Shipment.ActualDeliveryDate.HasValue)
                                    {
                                        <div class="small text-success"><i class="bi bi-check-circle"></i> Delivered @Model.Shipment.ActualDeliveryDate.Value.ToString("MMM dd, yyyy HH:mm")</div>
                                    }
                                </div>
                            </div>
                        </div>

                        <!-- Tracking Timeline -->
                        @if (Model.Shipment.TrackingEvents.Any())
                        {
                            <h6 class="mt-4 mb-3 fw-bold"><i class="bi bi-clock-history"></i> Tracking History</h6>
                            <div class="ao-tracking-timeline">
                                @foreach (var evt in Model.Shipment.TrackingEvents.OrderByDescending(e => e.EventDate))
                                {
                                    <div class="ao-track-event @(evt.Status.ToLower().Contains("delivered") ? "ao-track-delivered" : "")">
                                        <div class="ao-track-dot"></div>
                                        <div class="ao-track-content">
                                            <div class="d-flex justify-content-between">
                                                <strong>@evt.Status</strong>
                                                <small class="text-muted">@evt.EventDate.ToString("MMM dd, HH:mm")</small>
                                            </div>
                                            @if (!string.IsNullOrEmpty(evt.Location)) { <div class="small text-muted"><i class="bi bi-geo-alt"></i> @evt.Location</div> }
                                            @if (!string.IsNullOrEmpty(evt.Description)) { <div class="small mt-1">@evt.Description</div> }
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            }

            <!-- Return Requests -->
            @if (Model.ReturnRequests.Any())
            {
                <div class="ao-card mb-4">
                    <div class="ao-card-header">
                        <h5><i class="bi bi-arrow-return-left"></i> Return Requests <span class="ao-badge bg-warning text-dark">@Model.ReturnRequests.Count</span></h5>
                    </div>
                    <div class="ao-card-body">
                        @foreach (var ret in Model.ReturnRequests)
                        {
                            <div class="ao-return-item">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <div>
                                        <strong>Return #@ret.Id</strong> — @ret.ProductName
                                        <span class="badge bg-@(ret.Status == Kokomija.Entity.ReturnRequestStatus.Approved ? "success" : ret.Status == Kokomija.Entity.ReturnRequestStatus.Rejected ? "danger" : "warning") ms-2">@ret.Status</span>
                                    </div>
                                    <div class="fw-bold">@ret.RequestedAmount.ToString("N2") @Model.Currency</div>
                                </div>
                                <div class="row small text-muted">
                                    <div class="col-sm-4"><i class="bi bi-tag"></i> <strong>Reason:</strong> @ret.Reason</div>
                                    <div class="col-sm-4"><i class="bi bi-calendar3"></i> <strong>Requested:</strong> @ret.RequestedAt.ToString("MMM dd, yyyy HH:mm")</div>
                                    @if (ret.ReviewedAt.HasValue)
                                    {
                                        <div class="col-sm-4"><i class="bi bi-person-check"></i> <strong>Reviewed:</strong> @ret.ReviewedAt.Value.ToString("MMM dd, yyyy") @(ret.ReviewerName != null ? $"by {ret.ReviewerName}" : "")</div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }

            <!-- Admin Notes / Labels -->
            <div class="ao-card mb-4">
                <div class="ao-card-header">
                    <h5><i class="bi bi-sticky"></i> Admin Notes & Labels</h5>
                </div>
                <div class="ao-card-body">
                    <div id="adminNotesContainer" class="mb-3">
                        <div class="text-muted small" id="noNotesMsg"><i class="bi bi-info-circle"></i> No admin notes for this order yet.</div>
                    </div>
                    <div class="d-flex gap-2">
                        <div class="flex-grow-1">
                            <div class="input-group">
                                <span class="input-group-text bg-transparent"><i class="bi bi-chat-dots"></i></span>
                                <input type="text" id="adminNoteInput" class="form-control" placeholder="Add a note or label..." maxlength="200">
                            </div>
                        </div>
                        <select id="adminNoteType" class="form-select" style="width: auto;">
                            <option value="note">Note</option>
                            <option value="label-priority">Priority</option>
                            <option value="label-followup">Follow Up</option>
                            <option value="label-resolved">Resolved</option>
                            <option value="label-fraud">Fraud Check</option>
                        </select>
                        <button class="btn btn-primary" onclick="addAdminNote()"><i class="bi bi-plus-lg"></i> Add</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- ===== RIGHT COLUMN ===== -->
        <div class="col-xl-4">
            <!-- Customer Information -->
            <div class="ao-card mb-4">
                <div class="ao-card-header"><h5><i class="bi bi-person-badge"></i> Customer</h5></div>
                <div class="ao-card-body">
                    <div class="d-flex align-items-center gap-3 mb-3 pb-3 border-bottom">
                        <div class="ao-avatar"><i class="bi bi-person-fill"></i></div>
                        <div>
                            <div class="fw-bold">@Model.CustomerName</div>
                            <div class="small text-muted">@Model.CustomerEmail</div>
                            @if (!string.IsNullOrEmpty(Model.UserVipTier) && Model.UserVipTier != "None")
                            {
                                <span class="badge bg-gradient bg-warning text-dark mt-1"><i class="bi bi-star-fill"></i> @Model.UserVipTier VIP</span>
                            }
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.CustomerPhone))
                    {
                        <div class="ao-info-row"><span class="ao-info-label"><i class="bi bi-telephone"></i> Phone</span><span>@Model.CustomerPhone</span></div>
                    }
                    @if (Model.UserTotalSpent.HasValue)
                    {
                        <div class="ao-info-row"><span class="ao-info-label"><i class="bi bi-wallet2"></i> Total Spent</span><span class="fw-bold">@Model.UserTotalSpent.Value.ToString("N2") @Model.Currency</span></div>
                    }
                    <div class="mt-3">
                        <a href="mailto:@Model.CustomerEmail" class="btn btn-outline-primary btn-sm w-100"><i class="bi bi-envelope me-1"></i> Email Customer</a>
                    </div>
                </div>
            </div>

            <!-- Addresses -->
            <div class="ao-card mb-4">
                <div class="ao-card-header"><h5><i class="bi bi-geo-alt-fill"></i> Addresses</h5></div>
                <div class="ao-card-body">
                    <div class="mb-3">
                        <div class="ao-address-label"><i class="bi bi-truck me-1"></i> Shipping</div>
                        <address class="mb-0">
                            @Model.ShippingAddress?.Address<br>
                            @Model.ShippingAddress?.City, @Model.ShippingAddress?.State @Model.ShippingAddress?.PostalCode<br>
                            @Model.ShippingAddress?.Country
                        </address>
                    </div>
                    <hr class="my-2">
                    <div>
                        <div class="ao-address-label"><i class="bi bi-credit-card me-1"></i> Billing</div>
                        <address class="mb-0">
                            @Model.BillingAddress?.Address<br>
                            @Model.BillingAddress?.City, @Model.BillingAddress?.State @Model.BillingAddress?.PostalCode<br>
                            @Model.BillingAddress?.Country
                        </address>
                    </div>
                </div>
            </div>

            <!-- Payment Information -->
            <div class="ao-card mb-4">
                <div class="ao-card-header"><h5><i class="bi bi-wallet2"></i> Payment</h5></div>
                <div class="ao-card-body">
                    @if (Model.IsDemoOrder)
                    {
                        <div class="alert alert-info py-2 mb-3 small"><i class="bi bi-info-circle"></i> Demo data — Stripe IDs simulated</div>
                    }
                    <div class="ao-info-row">
                        <span class="ao-info-label">Status</span>
                        <span class="badge" style="background: @payColor;">@Model.PaymentStatus.ToUpper()</span>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.StripePaymentIntentId))
                    {
                        <div class="ao-info-row"><span class="ao-info-label">Payment Intent</span><code class="small @(Model.IsDemoOrder ? "text-muted" : "")">@Model.StripePaymentIntentId</code></div>
                    }
                    @if (!string.IsNullOrEmpty(Model.StripeChargeId))
                    {
                        <div class="ao-info-row"><span class="ao-info-label">Charge ID</span><code class="small @(Model.IsDemoOrder ? "text-muted" : "")">@Model.StripeChargeId</code></div>
                    }
                    @if (Model.PaidAt.HasValue)
                    {
                        <div class="ao-info-row"><span class="ao-info-label">Paid At</span><span>@Model.PaidAt.Value.ToString("MMM dd, yyyy HH:mm")</span></div>
                    }
                </div>
            </div>

            <!-- Quick Actions -->
            <div class="ao-card mb-4">
                <div class="ao-card-header"><h5><i class="bi bi-lightning-charge-fill"></i> Quick Actions</h5></div>
                <div class="ao-card-body">
                    <div class="d-grid gap-2">
                        @if (Model.OrderStatus != "cancelled" && Model.OrderStatus != "delivered")
                        {
                            <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#updateStatusModal">
                                <i class="bi bi-arrow-repeat me-1"></i> Update Status
                            </button>
                        }
                        @if (Model.Shipment == null && Model.OrderStatus != "cancelled" && Model.PaymentStatus == "paid")
                        {
                            <button type="button" class="btn btn-success btn-sm" data-bs-toggle="modal" data-bs-target="#createShipmentModal">
                                <i class="bi bi-truck me-1"></i> Create Shipment
                            </button>
                        }
                        @if (Model.Shipment != null && Model.Shipment.Status != Kokomija.Entity.ShipmentStatus.Delivered)
                        {
                            <button type="button" class="btn btn-info btn-sm text-white" data-bs-toggle="modal" data-bs-target="#addTrackingModal">
                                <i class="bi bi-pin-map me-1"></i> Add Tracking Event
                            </button>
                        }
                        @if (Model.PaymentStatus == "paid" && !Model.IsDemoOrder)
                        {
                            <button type="button" class="btn btn-outline-danger btn-sm" data-bs-toggle="modal" data-bs-target="#refundModal">
                                <i class="bi bi-arrow-counterclockwise me-1"></i> Refund Order
                            </button>
                        }
                    </div>
                </div>
            </div>

            <!-- Refund Information -->
            @if (Model.PaymentStatus == "refunded")
            {
                <div class="ao-card mb-4 border-danger">
                    <div class="ao-card-header bg-danger bg-opacity-10"><h5 class="text-danger"><i class="bi bi-arrow-counterclockwise"></i> Refund Info</h5></div>
                    <div class="ao-card-body">
                        @if (!string.IsNullOrEmpty(Model.StripeRefundId))
                        {
                            <div class="ao-info-row"><span class="ao-info-label">Refund ID</span><code class="small">@Model.StripeRefundId</code></div>
                        }
                        @if (Model.RefundedAmount.HasValue)
                        {
                            <div class="ao-info-row"><span class="ao-info-label">Amount</span><span class="fw-bold text-danger">@Model.RefundedAmount.Value.ToString("N2") @Model.Currency</span></div>
                        }
                        @if (Model.RefundedAt.HasValue)
                        {
                            <div class="ao-info-row"><span class="ao-info-label">Refunded At</span><span>@Model.RefundedAt.Value.ToString("MMM dd, yyyy HH:mm")</span></div>
                        }
                        @if (!string.IsNullOrEmpty(Model.RefundReason))
                        {
                            <div class="ao-info-row"><span class="ao-info-label">Reason</span><span>@Model.RefundReason</span></div>
                        }
                    </div>
                </div>
            }

            <!-- Developer Earnings -->
            @if (Model.DeveloperEarnings != null)
            {
                <div class="ao-card mb-4">
                    <div class="ao-card-header"><h5><i class="bi bi-cash-stack"></i> Developer Earnings</h5></div>
                    <div class="ao-card-body">
                        <div class="ao-info-row"><span class="ao-info-label">Gross</span><span>@Model.DeveloperEarnings.GrossAmount.ToString("N2") PLN</span></div>
                        <div class="ao-info-row"><span class="ao-info-label">Commission</span><span class="text-danger">-@Model.DeveloperEarnings.DeveloperCommission.ToString("N2") PLN</span></div>
                        <div class="ao-info-row"><span class="ao-info-label">Stripe Fee</span><span class="text-danger">-@Model.DeveloperEarnings.StripeProcessingFee.ToString("N2") PLN</span></div>
                        <div class="ao-info-row border-top pt-2 mt-2"><span class="ao-info-label fw-bold">Net Earnings</span><span class="fw-bold text-success">@Model.DeveloperEarnings.NetAmount.ToString("N2") PLN</span></div>
                        <div class="ao-info-row">
                            <span class="ao-info-label">Payout Status</span>
                            <span class="badge bg-@(Model.DeveloperEarnings.PayoutStatus == Kokomija.Entity.PayoutStatus.Processed ? "success" : "warning")">@Model.DeveloperEarnings.PayoutStatus.ToString().ToUpper()</span>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<!-- Update Status Modal -->
<div class="modal fade" id="updateStatusModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header"><h5 class="modal-title"><i class="bi bi-arrow-repeat me-2"></i>Update Order Status</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body">
                <form id="updateStatusForm">
                    <input type="hidden" name="orderId" value="@Model.Id">
                    <div class="mb-3">
                        <label class="form-label fw-medium">New Status</label>
                        <select name="newStatus" id="statusSelect" class="form-select" required>
                            <option value="">Select Status...</option>
                            <option value="pending">Pending</option>
                            <option value="processing">Processing</option>
                            <option value="shipped">Shipped</option>
                            <option value="delivered">Delivered</option>
                            <option value="cancelled">Cancelled</option>
                        </select>
                        <script>document.getElementById('statusSelect').value = '@Model.OrderStatus';</script>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium">Notes (Optional)</label>
                        <textarea name="notes" class="form-control" rows="3" placeholder="Add internal notes about this status change..."></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="updateOrderStatus()"><i class="bi bi-check-lg me-1"></i>Update</button>
            </div>
        </div>
    </div>
</div>

<!-- Create Shipment Modal -->
<div class="modal fade" id="createShipmentModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header"><h5 class="modal-title"><i class="bi bi-truck me-2"></i>Create Shipment</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body">
                <form id="createShipmentForm">
                    <input type="hidden" name="orderId" value="@Model.Id">
                    <div class="mb-3"><label class="form-label fw-medium">Shipping Provider</label><select name="shippingProviderId" class="form-select" required><option value="">Select Provider...</option></select></div>
                    <div class="mb-3"><label class="form-label fw-medium">Shipping Rate</label><select name="shippingRateId" class="form-select" required><option value="">Select Rate...</option></select></div>
                    <div class="mb-3"><label class="form-label fw-medium">Tracking Number</label><input type="text" name="trackingNumber" class="form-control" required></div>
                    <div class="row">
                        <div class="col-6 mb-3"><label class="form-label fw-medium">Weight (kg)</label><input type="number" name="weight" class="form-control" step="0.01" min="0"></div>
                        <div class="col-6 mb-3"><label class="form-label fw-medium">Est. Delivery</label><input type="date" name="estimatedDeliveryDate" class="form-control"></div>
                    </div>
                </form>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-success" onclick="createShipment()"><i class="bi bi-check-lg me-1"></i>Create</button>
            </div>
        </div>
    </div>
</div>

<!-- Add Tracking Event Modal -->
<div class="modal fade" id="addTrackingModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header"><h5 class="modal-title"><i class="bi bi-pin-map me-2"></i>Add Tracking Event</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body">
                <form id="addTrackingForm">
                    <input type="hidden" name="shipmentId" value="@Model.Shipment?.Id">
                    <div class="mb-3">
                        <label class="form-label fw-medium">Status</label>
                        <select name="status" class="form-select" required>
                            <option value="">Select...</option>
                            <option value="Pending">Pending</option><option value="Processing">Processing</option><option value="Shipped">Shipped</option>
                            <option value="In Transit">In Transit</option><option value="Out for Delivery">Out for Delivery</option>
                            <option value="Delivered">Delivered</option><option value="Failed">Failed</option><option value="Returned">Returned</option>
                        </select>
                    </div>
                    <div class="row">
                        <div class="col-6 mb-3"><label class="form-label fw-medium">Location</label><input type="text" name="location" class="form-control" placeholder="City, Country"></div>
                        <div class="col-6 mb-3"><label class="form-label fw-medium">Date</label><input type="datetime-local" name="eventDate" class="form-control" value="@DateTime.UtcNow.ToString("yyyy-MM-ddTHH:mm")"></div>
                    </div>
                    <div class="mb-3"><label class="form-label fw-medium">Description</label><textarea name="description" class="form-control" rows="2"></textarea></div>
                </form>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-info text-white" onclick="addTrackingEvent()"><i class="bi bi-check-lg me-1"></i>Add Event</button>
            </div>
        </div>
    </div>
</div>

<!-- Refund Order Modal -->
<div class="modal fade" id="refundModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-danger text-white"><h5 class="modal-title"><i class="bi bi-arrow-counterclockwise me-2"></i>Refund Order</h5><button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div>
            <div class="modal-body">
                <div class="alert alert-warning mb-3"><i class="bi bi-exclamation-triangle"></i> <strong>Warning:</strong> Refunds via Stripe cannot be undone. Stripe processing fees are NOT refunded.</div>
                <form id="refundForm">
                    <input type="hidden" name="orderId" value="@Model.Id">
                    <div class="mb-3"><label class="form-label fw-bold">Order Total</label><div class="fs-4 fw-bold">@Model.TotalAmount.ToString("N2") @Model.Currency</div></div>
                    <div class="mb-3">
                        <label class="form-label fw-medium">Refund Type</label>
                        <div class="form-check"><input class="form-check-input" type="radio" name="refundType" id="fullRefund" value="full" checked onchange="togglePartialAmount()"><label class="form-check-label" for="fullRefund">Full Refund (@Model.TotalAmount.ToString("N2") @Model.Currency)</label></div>
                        <div class="form-check"><input class="form-check-input" type="radio" name="refundType" id="partialRefund" value="partial" onchange="togglePartialAmount()"><label class="form-check-label" for="partialRefund">Partial Refund</label></div>
                    </div>
                    <div class="mb-3" id="partialAmountContainer" style="display: none;">
                        <label class="form-label">Refund Amount</label>
                        <div class="input-group"><input type="number" name="amount" id="refundAmount" class="form-control" step="0.01" min="0.01" max="@Model.TotalAmount"><span class="input-group-text">@Model.Currency</span></div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium">Reason</label>
                        <select name="reason" class="form-select" required>
                            <option value="requested_by_customer">Customer Request</option><option value="duplicate">Duplicate Payment</option><option value="fraudulent">Fraudulent</option>
                            <option value="product_not_received">Not Received</option><option value="product_damaged">Damaged</option><option value="wrong_item">Wrong Item</option><option value="other">Other</option>
                        </select>
                    </div>
                    <div class="mb-3"><label class="form-label fw-medium">Admin Notes</label><textarea name="adminNote" class="form-control" rows="2" placeholder="Internal notes..."></textarea></div>
                </form>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" onclick="processRefund()" id="refundBtn"><i class="bi bi-arrow-counterclockwise me-1"></i>Process Refund</button>
            </div>
        </div>
    </div>
</div>

</div>

