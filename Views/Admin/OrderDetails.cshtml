@section Scripts {
    <script>
        // ===== Admin Notes (client-side only, stored in localStorage) =====
        const notesKey = 'admin_notes_order_@Model.Id';
        function loadNotes() {
            const notes = JSON.parse(localStorage.getItem(notesKey) || '[]');
            const container = document.getElementById('adminNotesContainer');
            const noMsg = document.getElementById('noNotesMsg');
            if (notes.length === 0) { noMsg.style.display = 'block'; return; }
            noMsg.style.display = 'none';
            container.innerHTML = '';
            notes.forEach((n, i) => {
                const isLabel = n.type.startsWith('label-');
                const labelClass = isLabel ? `ao-label ao-${n.type}` : '';
                const prefix = isLabel ? `<span class="${labelClass}">${escapeHtml(n.type.replace('label-','').toUpperCase())}</span> ` : '';
                container.innerHTML += `<div class="ao-note">${prefix}<span>${escapeHtml(n.text)}</span><small class="text-muted ms-2">${escapeHtml(n.date)}</small><span class="ao-note-close" onclick="removeNote(${i})"><i class="bi bi-x"></i></span></div>`;
            });
        }
        function addAdminNote() {
            const input = document.getElementById('adminNoteInput');
            const type = document.getElementById('adminNoteType').value;
            const text = input.value.trim();
            if (!text) return;
            const notes = JSON.parse(localStorage.getItem(notesKey) || '[]');
            notes.push({ text, type, date: new Date().toLocaleDateString('en-GB', { day:'2-digit', month:'short', hour:'2-digit', minute:'2-digit' }) });
            localStorage.setItem(notesKey, JSON.stringify(notes));
            input.value = '';
            loadNotes();
        }
        function removeNote(idx) {
            const notes = JSON.parse(localStorage.getItem(notesKey) || '[]');
            notes.splice(idx, 1);
            localStorage.setItem(notesKey, JSON.stringify(notes));
            loadNotes();
        }
        function escapeHtml(t) { const d=document.createElement('div'); d.textContent=t; return d.innerHTML; }
        document.addEventListener('DOMContentLoaded', loadNotes);

        // ===== Order Actions =====
        function updateOrderStatus() {
            const form = document.getElementById('updateStatusForm');
            const formData = new FormData(form);
            fetch('@Url.Action("UpdateOrderStatus", "Admin")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ orderId: parseInt(formData.get('orderId')), newStatus: formData.get('newStatus'), notes: formData.get('notes') })
            }).then(r => r.json()).then(data => { if (data.success) location.reload(); else alert('Error: ' + data.message); }).catch(() => alert('An error occurred'));
        }

        function createShipment() {
            const form = document.getElementById('createShipmentForm');
            const formData = new FormData(form);
            fetch('@Url.Action("CreateOrderShipment", "Admin")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ orderId: parseInt(formData.get('orderId')), shippingProviderId: parseInt(formData.get('shippingProviderId')), shippingRateId: parseInt(formData.get('shippingRateId')), trackingNumber: formData.get('trackingNumber'), weight: parseFloat(formData.get('weight')), estimatedDeliveryDate: formData.get('estimatedDeliveryDate') })
            }).then(r => r.json()).then(data => { if (data.success) location.reload(); else alert('Error: ' + data.message); }).catch(() => alert('An error occurred'));
        }

        function addTrackingEvent() {
            const form = document.getElementById('addTrackingForm');
            const formData = new FormData(form);
            fetch('@Url.Action("AddOrderTrackingEvent", "Admin")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ shipmentId: parseInt(formData.get('shipmentId')), status: formData.get('status'), location: formData.get('location'), description: formData.get('description'), eventDate: formData.get('eventDate') })
            }).then(r => r.json()).then(data => { if (data.success) location.reload(); else alert('Error: ' + data.message); }).catch(() => alert('An error occurred'));
        }
        
        function togglePartialAmount() {
            const p = document.getElementById('partialRefund');
            const c = document.getElementById('partialAmountContainer');
            const a = document.getElementById('refundAmount');
            c.style.display = p.checked ? 'block' : 'none';
            a.required = p.checked;
            if (!p.checked) a.value = '';
        }
        
        function processRefund() {
            const form = document.getElementById('refundForm');
            const formData = new FormData(form);
            const btn = document.getElementById('refundBtn');
            const refundType = formData.get('refundType');
            const amount = refundType === 'partial' ? parseFloat(formData.get('amount')) : null;
            if (refundType === 'partial' && (!amount || amount <= 0 || amount > @Model.TotalAmount)) { alert('Invalid refund amount'); return; }
            const msg = refundType === 'partial' ? `Refund ${amount.toFixed(2)} @Model.Currency?` : `Full refund @Model.TotalAmount.ToString("N2") @Model.Currency?`;
            if (!confirm(msg)) return;
            btn.disabled = true; btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Processing...';
            fetch('@Url.Action("RefundOrder", "Admin")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ orderId: parseInt(formData.get('orderId')), amount, reason: formData.get('reason'), adminNote: formData.get('adminNote') })
            }).then(r => r.json()).then(data => {
                if (data.success) { alert(data.message); location.reload(); }
                else { alert('Error: ' + data.message); btn.disabled = false; btn.innerHTML = '<i class="bi bi-arrow-counterclockwise me-1"></i> Process Refund'; }
            }).catch(() => { alert('An error occurred'); btn.disabled = false; btn.innerHTML = '<i class="bi bi-arrow-counterclockwise me-1"></i> Process Refund'; });
        }
    </script>
}
</div>
